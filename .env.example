MOVA_MEDIA_ROOT=/absolute/path/to/media
# Optional for startup, required for TMDB metadata scraping. Use the API Read Access Token,
# not the shorter API Key (v3 auth): https://www.themoviedb.org/settings/api
MOVA_TMDB_ACCESS_TOKEN=
MOVA_WORKER_CONCURRENCY=2

# Optional for local source builds. Keep this commented on deployment hosts that should pull
# richeschiu/mova:latest instead of building from source.
# COMPOSE_FILE=docker-compose.yml:docker-compose.build.yml

# Optional proxy settings for Docker build stages and the mova-server runtime.
HTTP_PROXY=
HTTPS_PROXY=
