RUST_LOG=info,tower_http=info
MOVA_HTTP_HOST=0.0.0.0
MOVA_HTTP_PORT=8080
MOVA_TIMEZONE=Asia/Shanghai
MOVA_DATABASE_URL=postgres://mova:postgres@localhost:5432/mova
MOVA_DATABASE_MAX_CONNECTIONS=10
MOVA_CONFIG_DIR=./data/config
MOVA_CACHE_DIR=./data/cache
MOVA_TRANSCODE_DIR=./data/transcode
MOVA_MEDIA_BIND_SOURCE=./dev-media
MOVA_MEDIA_BIND_TARGET=/media/dev-media
MOVA_LIBRARY_ROOTS=/media/dev-media
